# =============================================================================
# Paper2Agent Studio — Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in the values you need.
# Never commit .env.local to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# AI Provider Selection
# ---------------------------------------------------------------------------
# Set PAPER2AGENT_CLI to one of: claude | codex | openrouter | gemini | qwen
# The default is "qwen" which uses Qwen 3.6 Plus FREE on OpenRouter.
PAPER2AGENT_CLI=qwen

# ---------------------------------------------------------------------------
# Qwen 3.6 Plus (FREE on OpenRouter — recommended)
# ---------------------------------------------------------------------------
# Model: qwen/qwen3.6-plus:free  (1M context, 65K output, $0)
# Get a free OpenRouter API key: https://openrouter.ai/keys
# No credit card required. Free tier has generous rate limits.
OPENROUTER_API_KEY=sk-or-v1-...
PAPER2AGENT_MODEL=qwen/qwen3.6-plus:free
PAPER2AGENT_BASE_URL=https://openrouter.ai/api/v1

# ---------------------------------------------------------------------------
# MiniMax M2.7 (Very cheap alternative — $0.30/M input, $1.20/M output)
# ---------------------------------------------------------------------------
# Uncomment to use M2.7 instead of Qwen. Requires paid OpenRouter credits.
# PAPER2AGENT_CLI=qwen
# PAPER2AGENT_MODEL=minimax/minimax-m2.7
# PAPER2AGENT_BASE_URL=https://openrouter.ai/api/v1

# ---------------------------------------------------------------------------
# Gemini (Google)
# ---------------------------------------------------------------------------
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# ---------------------------------------------------------------------------
# OpenRouter generic (use for any model available on OpenRouter)
# ---------------------------------------------------------------------------
# OPENROUTER_MODEL=openai/gpt-5.2-mini

# ---------------------------------------------------------------------------
# Claude (Anthropic) — requires Claude CLI, subscription needed
# ---------------------------------------------------------------------------
# PAPER2AGENT_CLI=claude
# PAPER2AGENT_MODEL=claude-sonnet-4-20250514

# ---------------------------------------------------------------------------
# Langfuse (optional — for observability and tracing)
# ---------------------------------------------------------------------------
# LANGFUSE_SECRET_KEY="sk-lf-YOUR_SECRET_KEY_HERE"
# LANGFUSE_PUBLIC_KEY="pk-lf-YOUR_PUBLIC_KEY_HERE"
# LANGFUSE_BASE_URL="https://cloud.langfuse.com"
